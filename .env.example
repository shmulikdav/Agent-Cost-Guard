# ─── Required ──────────────────────────────────────────────
# OpenAI API key
OPENAI_API_KEY=sk-...

# Slack bot — from api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...

# Slack signing secret — from Basic Information page
SLACK_SIGNING_SECRET=...

# Bearer token for admin endpoints (e.g. /admin/reset-monthly)
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=...

# ─── Optional ──────────────────────────────────────────────
# Slack channel for approvals and alerts
SLACK_CHANNEL=#ai-costs

# Monthly budget in USD — hard stop when exceeded
MONTHLY_BUDGET=200

# Requests at or above this cost (USD) need human approval
APPROVAL_THRESHOLD=10

# How long to wait for Slack approval before auto-denying (ms)
APPROVAL_TIMEOUT_MS=300000

# HTTP port
PORT=3000
